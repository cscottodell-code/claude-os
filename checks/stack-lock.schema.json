{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scott-toolkit/stack-lock.schema.json",
  "title": "stack-lock.json",
  "description": "Locks the approved technology stack for a project. Toolkit audits against these versions.",
  "type": "object",
  "required": ["schema_version", "locked", "approved_by", "tier", "technologies"],
  "properties": {
    "_readme": {
      "type": "string",
      "description": "Human-readable explanation of this file's purpose"
    },
    "schema_version": {
      "type": "string",
      "enum": ["1.0", "1.1"],
      "description": "Schema version for future migration support"
    },
    "locked": {
      "type": "string",
      "format": "date",
      "description": "Date this stack was locked (YYYY-MM-DD)"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "description": "Date this stack was last reviewed for staleness (YYYY-MM-DD)"
    },
    "approved_by": {
      "type": "string",
      "description": "Who approved this stack lock (typically 'scott')"
    },
    "tier": {
      "type": "string",
      "enum": ["full", "experiment"],
      "description": "full = production project with approval flow. experiment = auto-generated, no approval needed."
    },
    "technologies": {
      "type": "object",
      "description": "Map of technology name to version and audit config",
      "additionalProperties": {
        "type": "object",
        "required": ["version", "audit"],
        "properties": {
          "version": {
            "type": "string",
            "description": "Locked version (e.g., 'v3', '4', 'latest')"
          },
          "sdk": {
            "type": "string",
            "description": "SDK package and version (e.g., 'surrealdb@2.0.1')"
          },
          "audit": {
            "type": "boolean",
            "description": "Whether this technology should be audited"
          }
        }
      }
    },
    "services": {
      "type": "object",
      "description": "Non-code infrastructure services (hosting, cache, etc.)",
      "additionalProperties": {
        "type": "string"
      }
    },
    "paths": {
      "type": "object",
      "description": "Project-specific path mappings for monorepo support",
      "properties": {
        "schemas": { "type": "string" },
        "api": { "type": "string" },
        "frontend": { "type": "string" }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "exceptions": {
      "type": "array",
      "description": "Intentional deviations from stack rules (ACCEPT outcomes)",
      "items": {
        "type": "object",
        "required": ["check_id", "file", "reason", "accepted", "accepted_by"],
        "properties": {
          "check_id": {
            "type": "string",
            "description": "ID of the check being exempted"
          },
          "file": {
            "type": "string",
            "description": "File path the exception applies to"
          },
          "reason": {
            "type": "string",
            "description": "Why this deviation is intentional"
          },
          "accepted": {
            "type": "string",
            "format": "date",
            "description": "Date the exception was accepted (YYYY-MM-DD)"
          },
          "accepted_by": {
            "type": "string",
            "description": "Who accepted this exception"
          }
        }
      }
    }
  }
}
