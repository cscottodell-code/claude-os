{
  "technology": "tailwind",
  "golden_version": "4",
  "sdk": "tailwindcss@4",
  "dependencies": [],
  "context7_id": "/websites/tailwindcss",
  "file_patterns": ["*.css", "*.vue", "tailwind.config.*"],
  "content_patterns": ["@import \"tailwindcss\"", "tailwindcss"],
  "tools": [
    { "type": "context7", "id": "/websites/tailwindcss", "for": "Tailwind v4 docs" }
  ],
  "checks": {
    "static": [
      {
        "id": "tw-no-config-file",
        "pattern": "tailwind\\.config\\.(js|ts|cjs|mjs)",
        "message": "Tailwind v4 uses CSS-first config (@import 'tailwindcss'). Config files are not needed.",
        "severity": "warning"
      },
      {
        "id": "tw-shadow-renamed",
        "pattern": "\\bshadow\\b(?!-xs|-sm|-md|-lg|-xl|-2xl|-none|-inner)",
        "message": "In Tailwind v4: shadow -> shadow-sm, shadow-sm -> shadow-xs. Verify shadow utility names.",
        "severity": "warning",
        "file_filter": "*.vue"
      },
      {
        "id": "tw-ring-needs-width",
        "pattern": "\\bring\\b(?!-[0-9])",
        "message": "Tailwind v4 requires explicit ring width and color (e.g., ring-3 ring-blue-500).",
        "severity": "warning",
        "file_filter": "*.vue"
      }
    ],
    "live": []
  }
}
