{
  "technology": "bun",
  "golden_version": "latest",
  "sdk": null,
  "dependencies": [],
  "context7_id": null,
  "file_patterns": ["bunfig.toml", "bun.lockb"],
  "content_patterns": ["Bun\\.serve", "Bun\\.file", "bun:"],
  "tools": [
    { "type": "cli", "command": "bun --version", "for": "version check" }
  ],
  "checks": {
    "static": [
      {
        "id": "bun-no-node-fetch",
        "pattern": "import.*from ['\"]node-fetch['\"]",
        "message": "Bun has built-in fetch. Remove node-fetch dependency.",
        "severity": "warning"
      },
      {
        "id": "bun-no-dotenv",
        "pattern": "import.*from ['\"]dotenv['\"]",
        "message": "Bun reads .env natively. Remove dotenv dependency.",
        "severity": "warning"
      },
      {
        "id": "bun-surreal-db-create",
        "pattern": "db\\.create\\(",
        "message": "db.create() fails under Bun due to SurrealDB SDK transport differences. Use db.query() with type::record().",
        "severity": "error",
        "note": "Cross-reference with surreal-no-db-create-bun check"
      },
      {
        "id": "bun-surreal-db-update-merge",
        "pattern": "\\.update\\(.*\\.merge\\(",
        "message": "db.update().merge() fails under Bun. Use db.query() instead.",
        "severity": "error",
        "note": "Cross-reference with surreal-no-db-update-merge-bun check"
      }
    ],
    "live": []
  }
}
