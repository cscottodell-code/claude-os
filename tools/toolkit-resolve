#!/usr/bin/env bash
# toolkit-resolve — Resolve abstract operation names to concrete commands
# Reads config/interfaces.json and returns the command for a given operation.
# Usage: toolkit-resolve <operation_name>
#   Returns: the concrete command string (e.g., "/gsd:plan-phase")
#   Exit 0: resolved successfully
#   Exit 1: operation not found or interfaces.json missing

set -euo pipefail

TOOLKIT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
INTERFACES="${TOOLKIT_DIR}/config/interfaces.json"

if [[ $# -lt 1 ]]; then
  echo "Usage: toolkit-resolve <operation_name>" >&2
  echo "  Resolves an abstract operation to its concrete command." >&2
  echo "" >&2
  echo "Available operations:" >&2
  if [[ -f "$INTERFACES" ]]; then
    # Extract operation names from JSON
    # Extract only operation names (keys that have "command" on the next line)
    grep -B1 '"command":' "$INTERFACES" | grep -o '"[a-z_]*":' | grep -v '"command":' | tr -d '":' | sed 's/^/  /'
  fi
  exit 1
fi

OPERATION="$1"

if [[ ! -f "$INTERFACES" ]]; then
  echo "Error: interfaces.json not found at ${INTERFACES}" >&2
  exit 1
fi

# Extract the command for the given operation
# Uses grep + sed to avoid jq dependency
COMMAND=$(grep -A4 "\"${OPERATION}\":" "$INTERFACES" | grep '"command":' | head -1 | sed -E 's/.*"command":[ ]*"([^"]+)".*/\1/')

if [[ -z "$COMMAND" ]]; then
  echo "Unknown operation: ${OPERATION}. Check config/interfaces.json" >&2
  exit 1
fi

echo "$COMMAND"
