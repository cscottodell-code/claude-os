{
  "name": "scott-toolkit",
  "version": "6.1.0",
  "type": "module",
  "private": true,
  "description": "AI orchestration toolkit: hooks, tools, skills, and workflows for Claude Code",
  "scripts": {
    "lint": "bun run tools/toolkit-lint.ts",
    "check": "bun run tools/stack-check.ts",
    "detect": "bun run tools/stack-detect.ts",
    "preflight": "bun run tools/stack-preflight.ts",
    "metrics": "bun run tools/stack-metrics.ts",
    "sync": "bun run tools/toolkit-sync.ts",
    "graph": "bun run tools/toolkit-graph.ts",
    "graph:rebuild": "bun run tools/toolkit-graph.ts rebuild",
    "graph:impact": "bun run tools/toolkit-graph.ts impact",
    "graph:check": "bun run tools/toolkit-graph.ts check",
    "graph:stats": "bun run tools/toolkit-graph.ts stats"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "dependencies": {}
}
