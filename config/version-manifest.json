{
  "_readme": "Files that must reference the current toolkit version. Used by version-propagate.sh to detect stale references after CHANGELOG.md updates. 'files' are relative to toolkit dir, 'external_files' use ~/Sites/ as base.",
  "version_source": "CHANGELOG.md",
  "external_files": [
    {
      "path": "Global/context-engineering/compared-sources/toolkit-v5-optimization-brief.md",
      "description": "Optimization brief from compare-sources review"
    }
  ],
  "files": [
    {
      "path": "README.md",
      "pattern": "Toolkit v{VERSION}",
      "description": "Title heading"
    },
    {
      "path": "docs/user-guide.md",
      "pattern": "Toolkit v{VERSION}",
      "description": "Title heading"
    },
    {
      "path": "docs/v5-unified-design.md",
      "pattern": "Toolkit v{VERSION}",
      "description": "Design doc title"
    },
    {
      "path": "setup.sh",
      "pattern": "Toolkit v{VERSION}",
      "description": "Setup script comment and banner"
    },
    {
      "path": "rules/claude-behavior.md",
      "pattern": "Last updated:",
      "check": "date_freshness",
      "description": "Last updated date should match CHANGELOG date"
    },
    {
      "path": "skills/scott-toolkit-briefing/SKILL.md",
      "pattern": "CHANGELOG v{MAJOR_MINOR}",
      "description": "Constraint list should reference latest version"
    },
    {
      "path": "hooks/toolkit-coherence-check.sh",
      "pattern": "none",
      "check": "exists",
      "description": "Coherence check hook must exist"
    }
  ],
  "cross_reference_patterns": {
    "_readme": "Single source of truth for stale patterns. Read by toolkit-coherence-check.sh (real-time) and toolkit-lint.sh (batch). When renaming files or directories, add an entry here instead of hunting references manually.",
    "banned": [
      { "pattern": "~/scott-toolkit/", "replacement": "~/Sites/Global/scott-toolkit/", "reason": "Old shorthand path" },
      { "pattern": "scott-toolkit/templates/", "replacement": "scott-toolkit/context/", "reason": "Directory renamed in v4" },
      { "pattern": "toolkit/templates/", "replacement": "toolkit/context/", "reason": "Directory renamed in v4 (short form)" },
      { "pattern": "scott-toolkit-instructions.md", "replacement": "docs/user-guide.md", "reason": "File renamed in v5" },
      { "pattern": "skills/reference/", "replacement": "~/.claude/skills/ (skill system)", "reason": "Directory deleted in v4" }
    ],
    "scan_paths": {
      "_readme": "Paths to scan during full lint. Relative to ~/Sites/.",
      "toolkit": "Global/scott-toolkit",
      "external_claude_md": [
        "Advosy/*/CLAUDE.md",
        "Bresco/*/CLAUDE.md",
        "Personal/*/CLAUDE.md"
      ]
    }
  }
}
